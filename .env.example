# ─── Database (Postgres) ───────────────────────────────────────────────
# Neon of Supabase connection string. Lokaal bijv. een lokale Postgres.
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# ─── Mollie ────────────────────────────────────────────────────────────
# Test-key (test_...) tijdens ontwikkeling, live-key (live_...) in productie.
MOLLIE_API_KEY="test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── E-mail (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
# Afzender-adres (moet een geverifieerd domein in Resend zijn).
EMAIL_FROM="Muziekstudio Alkmaar <boekingen@booking.muziekstudioalkmaar.nl>"
# Kopie van elke boeking naar de studio (jouw eigen adres).
STUDIO_NOTIFY_EMAIL="info@muziekstudioalkmaar.nl"
# Interne notificatie bij elke boeking (standaard admin@muziekstudioalkmaar.nl).
ADMIN_NOTIFY_EMAIL="admin@muziekstudioalkmaar.nl"

# ─── App ───────────────────────────────────────────────────────────────
# Publieke basis-URL van de boekingssite. Nodig voor Mollie redirect + webhook.
# Lokaal: gebruik een tunnel (bijv. ngrok) zodat Mollie de webhook kan bereiken.
NEXT_PUBLIC_BASE_URL="https://booking.muziekstudioalkmaar.nl"

# Geheime sleutel waarmee de cron-endpoint zich authenticeert (zelf verzinnen).
CRON_SECRET="verzin-een-lange-willekeurige-string"

# Admin-wachtwoord voor het simpele beheerscherm (fase 1).
ADMIN_PASSWORD="verzin-een-sterk-wachtwoord"

# Geheime sleutel voor het ondertekenen van klant-sessies (min. 16 tekens).
# Genereer bijv. met:  openssl rand -base64 32
AUTH_SECRET="verzin-een-lange-willekeurige-string-min-16-tekens"
